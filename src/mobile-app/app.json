{
  "expo": {
    "name": "Vortex Sports AI",
    "slug": "vortex-sports-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/jugador.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/jugador.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E17"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vortex.sportsai",
      "buildNumber": "1.0.0"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/jugador.png",
        "backgroundColor": "#0A0E17"
      },
      "package": "com.vortex.sportsai",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/jugador.png"
    },
    "extra": {
      "eas": {
        "projectId": "your-project-id-here"
      }
    },
    "plugins": [
      "expo-sqlite",
      "expo-sharing"
    ]
  }
}
